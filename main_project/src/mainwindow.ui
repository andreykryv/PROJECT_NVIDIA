<?xml version="1.0" encoding="UTF-8"?>
<ui version="4.0">
 <customwidgets>
  <customwidget>
   <class>ControlPanel</class>
   <extends>QWidget</extends>
   <header>ui/controlpanel.h</header>
  </customwidget>
  <customwidget>
   <class>VisualizationWidget</class>
   <extends>QWidget</extends>
   <header>ui/visualizationwidget.h</header>
  </customwidget>
  <customwidget>
   <class>ChartWidget</class>
   <extends>QWidget</extends>
   <header>ui/chartwidget.h</header>
  </customwidget>
 </customwidgets>

 <class>MainWindow</class>
 <widget class="QMainWindow" name="MainWindow">
  <property name="geometry">
   <rect>
    <x>100</x>
    <y>100</y>
    <width>1440</width>
    <height>900</height>
   </rect>
  </property>
  <property name="minimumSize">
   <size>
    <width>1200</width>
    <height>800</height>
   </size>
  </property>
  <property name="windowTitle">
   <string>SortBench — CUDA vs CPU Sorting Benchmark</string>
  </property>
  <property name="windowIcon">
   <iconset resource="../resources/resources.qrc">
    <normaloff>:/icons/app_icon.png</normaloff>
   </iconset>
  </property>
  <property name="styleSheet">
   <string notr="true"/>
  </property>

  <!-- Центральное виджет -->
  <widget class="QWidget" name="centralWidget">
   <layout class="QHBoxLayout" name="mainLayout">
    <property name="spacing">
     <number>0</number>
    </property>
    <property name="leftMargin">
     <number>0</number>
    </property>
    <property name="topMargin">
     <number>0</number>
    </property>
    <property name="rightMargin">
     <number>0</number>
    </property>
    <property name="bottomMargin">
     <number>0</number>
    </property>

    <item>
     <widget class="QSplitter" name="mainSplitter">
      <property name="orientation">
       <enum>Qt::Horizontal</enum>
      </property>
      <property name="handleWidth">
       <number>4</number>
      </property>

      <!-- Левая панель: Управление и статистика -->
      <widget class="QWidget" name="leftPanel">
       <property name="minimumSize">
        <size>
         <width>320</width>
         <height>0</height>
        </size>
       </property>
       <property name="maximumSize">
        <size>
         <width>450</width>
         <height>16777215</height>
        </size>
       </property>
       <layout class="QVBoxLayout" name="leftLayout">
        <property name="spacing">
         <number>10</number>
        </property>
        <property name="leftMargin">
         <number>10</number>
        </property>
        <property name="topMargin">
         <number>10</number>
        </property>
        <property name="rightMargin">
         <number>10</number>
        </property>
        <property name="bottomMargin">
         <number>10</number>
        </property>

        <!-- Панель управления (Promoted Widget) -->
        <item>
         <widget class="ControlPanel" name="controlPanel">
          <property name="sizePolicy">
           <sizepolicy hsizetype="Preferred" vsizetype="Fixed">
            <horstretch>0</horstretch>
            <verstretch>0</verstretch>
           </sizepolicy>
          </property>
         </widget>
        </item>

        <!-- Виджет прогресса -->
        <item>
         <widget class="QWidget" name="progressContainer">
          <layout class="QVBoxLayout" name="progressLayout">
           <property name="leftMargin">
            <number>0</number>
           </property>
           <property name="topMargin">
            <number>0</number>
           </property>
           <property name="rightMargin">
            <number>0</number>
           </property>
           <property name="bottomMargin">
            <number>0</number>
           </property>
           <!-- Сюда программно добавляется QProgressBar или StatsPanel -->
          </layout>
         </widget>
        </item>

        <item>
         <spacer name="verticalSpacer">
          <property name="orientation">
           <enum>Qt::Vertical</enum>
          </property>
          <property name="sizeHint" stdset="0">
           <size>
            <width>20</width>
            <height>40</height>
           </size>
          </property>
         </spacer>
        </item>
       </layout>
      </widget>

      <!-- Правая панель: Визуализация и Графики -->
      <widget class="QWidget" name="rightPanel">
       <layout class="QVBoxLayout" name="rightLayout">
        <property name="spacing">
         <number>0</number>
        </property>
        <property name="leftMargin">
         <number>0</number>
        </property>
        <property name="topMargin">
         <number>0</number>
        </property>
        <property name="rightMargin">
         <number>0</number>
        </property>
        <property name="bottomMargin">
         <number>0</number>
        </property>

        <item>
         <widget class="QTabWidget" name="mainTabWidget">
          <property name="currentIndex">
           <number>0</number>
          </property>
          <property name="documentMode">
           <bool>false</bool>
          </property>
          <property name="tabsClosable">
           <bool>false</bool>
          </property>

          <!-- Вкладка 1: Визуализация -->
          <widget class="QWidget" name="tabVisualization">
           <attribute name="title">
            <string>📊 Визуализация</string>
           </attribute>
           <layout class="QVBoxLayout" name="vizLayout">
            <property name="spacing">
             <number>0</number>
            </property>
            <property name="leftMargin">
             <number>0</number>
            </property>
            <property name="topMargin">
             <number>0</number>
            </property>
            <property name="rightMargin">
             <number>0</number>
            </property>
            <property name="bottomMargin">
             <number>0</number>
            </property>

            <item>
             <widget class="VisualizationWidget" name="visualizationWidget">
              <property name="autoFillBackground">
               <bool>false</bool>
              </property>
             </widget>
            </item>
           </layout>
          </widget>

          <!-- Вкладка 2: Графики -->
          <widget class="QWidget" name="tabCharts">
           <attribute name="title">
            <string>📈 Графики производительности</string>
           </attribute>
           <layout class="QVBoxLayout" name="chartLayout">
            <property name="spacing">
             <number>0</number>
            </property>
            <property name="leftMargin">
             <number>0</number>
            </property>
            <property name="topMargin">
             <number>0</number>
            </property>
            <property name="rightMargin">
             <number>0</number>
            </property>
            <property name="bottomMargin">
             <number>0</number>
            </property>

            <item>
             <widget class="ChartWidget" name="chartWidget"/>
            </item>
           </layout>
          </widget>

          <!-- Вкладка 3: Таблица результатов -->
          <widget class="QWidget" name="tabResults">
           <attribute name="title">
            <string>📋 Таблица результатов</string>
           </attribute>
           <layout class="QVBoxLayout" name="tableLayout">
            <property name="leftMargin">
             <number>5</number>
            </property>
            <property name="topMargin">
             <number>5</number>
            </property>
            <property name="rightMargin">
             <number>5</number>
            </property>
            <property name="bottomMargin">
             <number>5</number>
            </property>

            <item>
             <widget class="QTableView" name="resultsTable">
              <property name="alternatingRowColors">
               <bool>true</bool>
              </property>
              <property name="selectionBehavior">
               <enum>QAbstractItemView::SelectRows</enum>
              </property>
              <property name="sortingEnabled">
               <bool>true</bool>
              </property>
             </widget>
            </item>
           </layout>
          </widget>
         </widget>
        </item>
       </layout>
      </widget>
     </widget>
    </item>
   </layout>
  </widget>

  <!-- Строка меню -->
  <widget class="QMenuBar" name="menuBar">
   <property name="geometry">
    <rect>
     <x>0</x>
     <y>0</y>
     <width>1440</width>
     <height>25</height>
    </rect>
   </property>

   <widget class="QMenu" name="menuFile">
    <property name="title">
     <string>Файл</string>
    </property>
    <addaction name="actionExportCSV"/>
    <addaction name="actionExportJSON"/>
    <addaction name="separator"/>
    <addaction name="actionSettings"/>
    <addaction name="separator"/>
    <addaction name="actionExit"/>
   </widget>

   <widget class="QMenu" name="menuView">
    <property name="title">
     <string>Вид</string>
    </property>
    <addaction name="actionToggleDarkMode"/>
    <addaction name="actionResetZoom"/>
    <addaction name="separator"/>
    <addaction name="actionShowLogDock"/>
   </widget>

   <widget class="QMenu" name="menuHelp">
    <property name="title">
     <string>Справка</string>
    </property>
    <addaction name="actionAbout"/>
    <addaction name="actionAboutQt"/>
   </widget>

   <addaction name="menuFile"/>
   <addaction name="menuView"/>
   <addaction name="menuHelp"/>
  </widget>

  <!-- Строка состояния -->
  <widget class="QStatusBar" name="statusBar">
   <property name="sizeGripEnabled">
    <bool>true</bool>
   </property>
  </widget>

  <!-- Действия -->
  <action name="actionExportCSV">
   <property name="text">
    <string>Экспорт в CSV...</string>
   </property>
   <property name="shortcut">
    <string>Ctrl+S</string>
   </property>
  </action>

  <action name="actionExportJSON">
   <property name="text">
    <string>Экспорт в JSON...</string>
   </property>
  </action>

  <action name="actionSettings">
   <property name="text">
    <string>Настройки...</string>
   </property>
   <property name="shortcut">
    <string>Ctrl+,</string>
   </property>
  </action>

  <action name="actionExit">
   <property name="text">
    <string>Выход</string>
   </property>
   <property name="shortcut">
    <string>Alt+F4</string>
   </property>
  </action>

  <action name="actionToggleDarkMode">
   <property name="checkable">
    <bool>true</bool>
   </property>
   <property name="text">
    <string>Тёмная тема</string>
   </property>
   <property name="shortcut">
    <string>F2</string>
   </property>
  </action>

  <action name="actionResetZoom">
   <property name="text">
    <string>Сбросить масштаб</string>
   </property>
   <property name="shortcut">
    <string>Ctrl+0</string>
   </property>
  </action>

  <action name="actionShowLogDock">
   <property name="checkable">
    <bool>true</bool>
   </property>
   <property name="checked">
    <bool>false</bool>
   </property>
   <property name="text">
    <string>Панель логов</string>
   </property>
  </action>

  <action name="actionAbout">
   <property name="text">
    <string>О программе SortBench...</string>
   </property>
  </action>

  <action name="actionAboutQt">
   <property name="text">
    <string>О Qt...</string>
   </property>
  </action>
 </widget>

 <resources>
  <include location="../resources/resources.qrc"/>
 </resources>

 <connections/>
</ui>