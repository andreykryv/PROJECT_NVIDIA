    <!-- Вкладка 4: Экспорт и логирование -->
    <widget class="QWidget" name="exportTab">
     <attribute name="title">
      <string>Экспорт и логи</string>
     </attribute>
     <layout class="QVBoxLayout" name="exportLayout">
      <property name="spacing">
       <number>12</number>
      </property>

      <!-- Группа: Форматы экспорта -->
      <widget class="QGroupBox" name="exportFormatGroup">
       <property name="title">
